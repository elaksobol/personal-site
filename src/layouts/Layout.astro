---
import Navigation from '../components/Navigation.astro';

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
        <style is:global>
          :root {
            --soft-blue: #e3f2fd;
            --soft-green: #e8f5e9;
            --soft-pink: #fce4ec;
            --text-main: #2c3e50;
          }
          body { 
            font-family: 'Helvetica Neue', Arial, sans-serif; 
            line-height: 1.6; 
            margin: 0; 
            padding: 0; 
            color: var(--text-main);
            background-color: #ffffff;
          }
          main { padding: 0; max-width: 100%; margin: auto; }
        </style>
  </head>
  <body>
    
    <Navigation />

    <main>
      <slot />
    </main>
  </body>
</html>
