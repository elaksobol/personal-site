---
import Layout from '../layouts/Layout.astro';
const base = '/personal-site';
---

<Layout title="Resume | Ela Sobol">
  <main style="max-width: 900px; margin: 0 auto; padding: 3rem 2rem; font-family: 'Helvetica Neue', Arial, sans-serif; color: #333; line-height: 1.6;">
    
    <header style="text-align: center; margin-bottom: 2.5rem;">
      <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; color: #1a1a1a;">ELA SOBOL</h1>
      <p style="font-size: 1.1rem;">
        Williamsburg, VA | <a href="mailto:your-email@wm.edu" style="color: #007bff; text-decoration: none;">Email Me</a> | 
        <a href="https://linkedin.com/in/yourprofile" style="color: #007bff; text-decoration: none;">LinkedIn</a>
      </p>
    </header>

    <section style="margin-bottom: 2rem;">
      <h2 style="border-bottom: 2px solid #333; padding-bottom: 5px; text-transform: uppercase; letter-spacing: 1px;">Education</h2>
      <div style="margin-top: 1rem;">
        <div style="display: flex; justify-content: space-between; font-weight: bold;">
          <span>College of William & Mary</span>
          <span>Williamsburg, VA</span>
        </div>
        <div style="display: flex; justify-content: space-between; font-style: italic; color: #555;">
          <span>Bachelor of Science in Data Science and Psychology</span>
          <span>May 2026</span>
        </div>
        <ul style="margin-top: 0.5rem;">
          <li>Cumulative GPA: 3.96 | Dean’s List (Fall 2022 – Fall 2024)</li>
          <li>Relevant Coursework: Social Psychology, Developmental Psychology, Data Science</li>
        </ul>
      </div>

      <div style="margin-top: 1.5rem;">
        <div style="display: flex; justify-content: space-between; font-weight: bold;">
          <span>University of Cambridge (Pembroke College)</span>
          <span>Cambridge, UK</span>
        </div>
        <div style="display: flex; justify-content: space-between; font-style: italic; color: #555;">
          <span>Study Abroad</span>
          <span>Summer 2024</span>
        </div>
        <ul style="margin-top: 0.5rem;">
          <li>Coursework: Developmental Psychology and The Economics of Contemporary Britain</li>
        </ul>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="border-bottom: 2px solid #333; padding-bottom: 5px; text-transform: uppercase; letter-spacing: 1px;">Research & Work Experience</h2>
      
      <div style="margin-top: 1rem;">
        <div style="display: flex; justify-content: space-between; font-weight: bold;">
          <span>Research Assistant | DIGI Lab</span>
          <span>Aug 2023 – Present</span>
        </div>
        <ul style="margin-top: 0.5rem;">
          <li>Perform data cleaning and entry using SPSS for social psychology research</li>
          <li>Presented research findings at the William & Mary Undergraduate Research Symposium</li>
        </ul>
      </div>

      <div style="margin-top: 1.5rem;">
        <div style="display: flex; justify-content: space-between; font-weight: bold;">
          <span>Campus Tour Guide | W&M Undergraduate Admission</span>
          <span>Aug 2023 – Present</span>
        </div>
        <ul style="margin-top: 0.5rem;">
          <li>Lead prospective students and families on walking tours, representing the university's values and history</li>
        </ul>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="border-bottom: 2px solid #333; padding-bottom: 5px; text-transform: uppercase; letter-spacing: 1px;">Leadership & Involvement</h2>
      
      <div style="margin-top: 1rem;">
        <div style="display: flex; justify-content: space-between; font-weight: bold;">
          <span>President | Pointe Blank Dance Company</span>
          <span>May 2024 – Present</span>
        </div>
        <p style="font-style: italic; color: #555; margin: 0.2rem 0;">(Public Relations Chair: May 2023 – May 2024)</p>
        <ul style="margin-top: 0.5rem;">
          <li>Manage 70+ members and oversee university relations and semesterly dues</li>
          <li>Coordinate all organizational logistics for large-scale semesterly showcases</li>
        </ul>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="border-bottom: 2px solid #333; padding-bottom: 5px; text-transform: uppercase; letter-spacing: 1px;">Skills</h2>
      <p style="margin-top: 1rem;">
        <strong>Technical:</strong> Python, R, SPSS, Tableau, Microsoft Office Suite<br />
        <strong>Soft Skills:</strong> Public Speaking, Data Analysis, Project Management, Strategic Communication
      </p>
    </section>

    <footer style="margin-top: 4rem; text-align: center; border-top: 1px solid #eee; padding-top: 1rem;">
      <a href={`${base}/`} style="color: #007bff; text-decoration: none; font-weight: bold;">← Return to Home</a>
    </footer>

  </main>
</Layout>
