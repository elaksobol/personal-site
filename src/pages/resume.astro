---
import Layout from '../layouts/Layout.astro';
const base = '/personal-site';
---

<Layout title="Resume | Ela Sobol">
  <main style="max-width: 900px; margin: 0 auto; padding: 3rem 2rem; font-family: 'Helvetica Neue', Arial, sans-serif; color: #333; line-height: 1.6;">
    
    <header style="display: flex; align-items: center; gap: 2.5rem; margin-bottom: 2.5rem; border-bottom: 2px solid #333; padding-bottom: 20px; flex-wrap: wrap;">
      <img src={`${base}/resume.jpeg`} alt="Ela Sobol" style="width: 160px; height: 200px; border-radius: 10px; object-fit: cover; box-shadow: 5px 5px 15px rgba(0,0,0,0.1);" />
      
      <div style="flex: 1; min-width: 300px;">
        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; color: #1a1a1a; text-transform: uppercase;">ELA SOBOL</h1>
        <p style="font-size: 1.1rem; margin: 0;">
          Centreville, VA • 703-405-6001 • <a href="mailto:elaksobol@gmail.com" style="color: #007bff; text-decoration: none;">elaksobol@gmail.com</a>
        </p>
      </div>
    </header>

    <section style="margin-bottom: 2rem;">
      <h2 style="text-transform: uppercase; letter-spacing: 1px; font-size: 1.3rem; margin-bottom: 10px;">Education</h2>
      <div style="margin-top: 0.5rem;">
        <div style="display: flex; justify-content: space-between; font-weight: bold;">
          <span>William & Mary, Williamsburg, VA</span>
          <span>May 2027</span>
        </div>
        <p style="margin: 0.2rem 0;">Bachelor of Science, Majors: Data Science, Psychology, GPA: 3.96</p>
        <p style="margin: 0.2rem 0;"><strong>Relevant Coursework:</strong> Applied Machine Learning, Data Visualization, Statistical Data Analysis, Psychology Research Methods, Databases</p>
        <p style="margin: 0.2rem 0;">Study Abroad, University of Cambridge, England</p>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="text-transform: uppercase; letter-spacing: 1px; font-size: 1.3rem; margin-bottom: 10px;">Skills</h2>
      <div style="margin-top: 0.5rem;">
        <p style="margin: 0.2rem 0;"><strong>Languages:</strong> Python, R/RStudio (Statistical Analysis)</p>
        <p style="margin: 0.2rem 0;"><strong>Tools/Libraries:</strong> Pandas, Numpy, Tableau, Matplotlib, SPSS, Qualtrics</p>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="text-transform: uppercase; letter-spacing: 1px; font-size: 1.3rem; margin-bottom: 10px;">Research Experience</h2>
      <div style="margin-top: 0.5rem;">
        <div style="display: flex; justify-content: space-between; font-weight: bold;">
          <span>DiGI Lab Research Assistant, William & Mary</span>
          <span>August 2025 - Present</span>
        </div>
        <ul style="margin-top: 0.5rem; padding-left: 1.5rem;">
          <li>Assisted in faculty psychology research by collecting, cleaning, and analyzing data</li>
          <li>Collaborated with faculty and peers to meet timelines and follow ethical standards</li>
        </ul>
      </div>
      <div style="margin-top: 1.5rem;">
        <div style="display: flex; justify-content: space-between; font-weight: bold;">
          <span>Presenter, William & Mary Research Symposium</span>
          <span>September 2025</span>
        </div>
        <ul style="margin-top: 0.5rem; padding-left: 1.5rem;">
          <li>Analyzed psychology research data using SPSS and interpreted statistical results</li>
          <li>Presented original research findings at an undergraduate symposium, effectively communicating methods, results, and implications to an academic audience</li>
        </ul>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="text-transform: uppercase; letter-spacing: 1px; font-size: 1.3rem; margin-bottom: 10px;">Leadership Experience</h2>
      <div style="margin-top: 0.5rem;">
        <div style="display: flex; justify-content: space-between; font-weight: bold;">
          <span>Campus Tour Guide, Undergraduate Admission, William & Mary</span>
          <span>September 2025 - Present</span>
        </div>
        <ul style="margin-top: 0.5rem; padding-left: 1.5rem;">
          <li>Selected through a competitive process to represent the university and deliver structured, audience-tailored presentation tours to prospective students and parents</li>
        </ul>
      </div>
      <div style="margin-top: 1.5rem;">
        <div style="display: flex; justify-content: space-between; font-weight: bold;">
          <span>President, Pointe Blank Dance Company, William & Mary</span>
          <span>December 2025 - Present</span>
        </div>
        <ul style="margin-top: 0.5rem; padding-left: 1.5rem;">
          <li>Managed scheduling, logistics, and internal operations for a 70-member dance organization, ensuring the smooth coordination of meetings, rehearsals, and showcases</li>
