---
import Layout from '../layouts/Layout.astro';
// This is the correct way to get the base path in Astro 5
const base = import.meta.env.BASE_URL;
---
<Layout title="Ela Sobol | Home">
  <div style="display: flex; flex-wrap: wrap; gap: 40px; align-items: center; margin-top: 2rem;">
    <div style="flex: 1; min-width: 300px;">
      <h1>Hi, I'm Ela Sobol </h1>
      <p>
        I am a Junior at <strong>William & Mary</strong> studying Data Science and Psychology.
        Currently, I am a Research Assistant at the <strong>DIGI Lab</strong>[cite: 14].
      </p>
      <p>
        I also lead the <strong>Pointe Blank Dance Company</strong> as President.
      </p>
      <a href={`${base}/resume`} style="background: #1a5fb4; color: white; padding: 10px 20px; border-radius: 5px; text-decoration: none; display: inline-block;">View My Resume</a>
    </div>
    <div style="flex: 1; min-width: 300px; text-align: center;">
      <img src={`${base}/me.jpg`} alt="Ela Sobol" style="width: 100%; max-width: 350px; border-radius: 20px;" />
    </div>
  </div>
</Layout>
